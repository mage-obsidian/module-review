<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="MageObsidian\Customer\ViewModel\AccountNav">
        <arguments>
            <argument name="links" xsi:type="array">
                <item name="reviews" xsi:type="array">
                    <item name="route" xsi:type="string">review/customer</item>
                    <item name="match" xsi:type="string">review_customer</item>
                    <item name="label" xsi:type="string" translate="true">My Product Reviews</item>
                    <item name="sortOrder" xsi:type="string">45</item>
                </item>
            </argument>
        </arguments>
    </type>
</config>
